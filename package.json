{
  "name": "seren",
  "version": "1.0.0",
  "description": "Seren - Plateforme d'accompagnement post-deces",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node --watch server/server.js",
    "dev:all": "concurrently -n vite,server -c green,blue \"npm run dev\" \"npm run dev:server\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production node server/server.js",
    "launch": "npm install && npm run build && npm start",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hookform/resolvers": "3.9.1",
    "@mistralai/mistralai": "2.2.0",
    "@radix-ui/react-slot": "1.2.4",
    "@supabase/supabase-js": "2.90.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "express": "4.18.2",
    "jspdf": "4.2.0",
    "lucide-react": "0.468.0",
    "posthog-js": "1.360.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "7.54.2",
    "react-router-dom": "7.1.1",
    "tailwind-merge": "2.6.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.2",
    "@types/express": "^5.0.6",
    "@types/node": "22.10.5",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "4.3.4",
    "concurrently": "9.1.2",
    "supertest": "^7.2.2",
    "tailwindcss": "4.2.2",
    "typescript": "~5.6.3",
    "vite": "6.0.7",
    "vitest": "4.1.10"
  }
}
